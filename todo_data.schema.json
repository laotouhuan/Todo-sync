{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TodoData",
  "description": "Schema for Nutstore To-Do App Data",
  "type": "object",
  "properties": {
    "version": {
      "type": "integer",
      "description": "Data schema version"
    },
    "last_updated": {
      "type": "string",
      "format": "date-time",
      "description": "Last updated timestamp in ISO 8601 format"
    },
    "todos": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "content": {
            "type": "string"
          },
          "date": {
            "type": ["string", "null"]
          },
          "time": {
            "type": ["string", "null"]
          },
          "completed_at": {
            "type": ["string", "null"],
            "format": "date-time"
          },
          "order": {
            "type": "number",
            "default": 0
          },
          "completed": {
            "type": "boolean"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "description": "Last modification timestamp, used for cloud sync conflict resolution"
          },
          "deleted": {
            "type": "boolean",
            "default": false,
            "description": "Soft-delete flag"
          },
          "recurring": {
            "type": "string",
            "enum": ["none", "daily_repeat"],
            "default": "none"
          },
          "task_type": {
            "type": "string",
            "enum": ["normal", "weekly_checkin", "monthly_checkin"],
            "default": "normal"
          },
          "completed_dates": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": []
          },
          "target_count": {
            "type": ["integer", "null"],
            "default": null
          },
          "subtasks": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string",
                  "format": "uuid"
                },
                "content": {
                  "type": "string"
                },
                "completed": {
                  "type": "boolean"
                },
                "completed_at": {
                  "type": ["string", "null"],
                  "format": "date-time",
                  "default": null
                }
              },
              "required": ["id", "content", "completed"]
            },
            "default": []
          }
        },
        "required": [
          "id",
          "content",
          "completed",
          "created_at"
        ]
      }
    }
  },
  "required": ["version", "last_updated", "todos"]
}
